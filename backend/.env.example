# === Base de données PostgreSQL ===
DATABASE_URL="postgresql://user:password@localhost:5432/formulaire_humanitour?schema=public"

# === Serveur ===
PORT=3535
NODE_ENV=development

# === Origines autorisées (CORS) — séparées par des virgules ===
# Doit lister TOUS les domaines depuis lesquels le frontend est servi.
FRONTEND_ORIGIN="https://humanitour.fr,https://www.humanitour.fr,https://klaynight.fr,https://www.klaynight.fr,https://forms.klaynight.fr,https://forms.humanitour.fr,http://localhost:5173"

# === Secrets (générer avec: openssl rand -base64 48) ===
# Clé de chiffrement AES-256-GCM des données sensibles au repos (32 octets encodés base64)
ENCRYPTION_KEY="CHANGE_ME_base64_de_32_octets_minimum_pour_AES_256_GCM=="
# Secret de signature des sessions / CSRF
SESSION_SECRET="CHANGE_ME_secret_long_et_aleatoire"

# === Sessions ===
# Durée de vie d'une session en secondes (défaut 7 jours)
SESSION_TTL=604800
# Mettre à true en production (HTTPS). Sera automatiquement mis à true si COOKIE_SAME_SITE est à 'none' ou si NODE_ENV est 'production'.
COOKIE_SECURE=false
# Politique SameSite des cookies (lax, strict, none). Utiliser 'none' en cas de domaines d'API intersite (contexte CORS).
COOKIE_SAME_SITE=lax

# === Uploads ===
UPLOAD_DIR="./uploads"
MAX_UPLOAD_BYTES=10485760

# === Emails (invitations, notifications) ===
# Origine publique du frontend utilisée pour construire les liens envoyés par email.
# Par défaut, la première valeur de FRONTEND_ORIGIN est utilisée.
APP_URL="http://localhost:5173"
#
# Transport prioritaire : Resend (API HTTP). Si RESEND_API_KEY est défini,
# il est utilisé à la place du SMTP. Créer la clé sur https://resend.com
# et vérifier le domaine d'envoi.
RESEND_API_KEY=""
# Adresse d'expéditeur (doit appartenir à un domaine vérifié dans Resend).
RESEND_FROM="no-reply@humanitour.fr"
#
# Fallback SMTP : utilisé uniquement si RESEND_API_KEY est vide.
# Sans Resend ni SMTP_HOST/USER/PASS, les emails sont affichés dans la console (mode dev).
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@openforms.org"
